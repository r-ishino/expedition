{
  "name": "expedition",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "docker compose up -d && pnpm --parallel -r run dev",
    "dev:frontend": "pnpm --filter @expedition/frontend dev",
    "dev:job-manager": "pnpm --filter @expedition/job-manager dev",
    "build": "pnpm -r run build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "fmt": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mdx,css,yaml,yml}\"",
    "fmt:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mdx,css,yaml,yml}\"",
    "tsc": "pnpm -r exec tsc --noEmit",
    "db:push": "pnpm --filter @expedition/job-manager db:push",
    "db:studio": "pnpm --filter @expedition/job-manager db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
